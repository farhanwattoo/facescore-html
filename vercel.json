{
    "headers": [
        {
            "source": "/(.*)\\.(css|js|svg|woff2|webp|avif|png|jpg|jpeg|gif|ico)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=604800, stale-while-revalidate=86400"
                }
            ]
        },
        {
            "source": "/models/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=604800"
                }
            ]
        },
        {
            "source": "/(.*)\\.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=1800, stale-while-revalidate=3600"
                }
            ]
        }
    ],
    "redirects": [
        {
            "source": "/index.html",
            "destination": "/",
            "permanent": true
        },
        {
            "source": "/index.php",
            "destination": "/",
            "permanent": true
        },
        {
            "source": "/about-us/",
            "destination": "/about-us",
            "permanent": true
        },
        {
            "source": "/:path+/",
            "destination": "/:path+",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/index.html",
            "destination": "/index.html"
        },
        {
            "source": "/about-us",
            "destination": "/about.html"
        }
    ]
}
